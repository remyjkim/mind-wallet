{
  "name": "mindwallet",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "mindwallet": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
