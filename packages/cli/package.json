{
  "name": "mindwallet",
  "version": "0.2.0",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/remyjkim/mind-wallet.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/remyjkim/mind-wallet#readme",
  "bugs": {
    "url": "https://github.com/remyjkim/mind-wallet/issues"
  },
  "keywords": [
    "http-402",
    "payments",
    "agents",
    "mcp",
    "cli",
    "wallet",
    "x402",
    "siwx",
    "tempo"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "mindwallet": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run build && bun run test"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mindwallet/core": "workspace:*",
    "@mindwallet/discovery": "workspace:*",
    "@mindwallet/protocols": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "viem": "^2.47.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@mindwallet/test-server": "workspace:*",
    "@open-wallet-standard/core": "^1.0.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
